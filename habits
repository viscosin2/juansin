    <div class="modal-title">Notificaciones</div>
    <div id="notifList"></div>
    <button class="btn-primary" onclick="closeModal('modalNotif')">Cerrar</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ════════════════════════════════════════════════
//  DATA
// ════════════════════════════════════════════════
const EMOJIS = ['💪','🧘','📚','💧','🏃','🥗','😴','✍️','🎵','🌿','🧠','❤️','🎯','🛏️','🚴','🧹','💊','🌞','🍎','🫁','🧘‍♀️','☕','🎨','🤸','🌙','🏋️','🦷','📝','🥤','🧴'];
const DAYS_LABELS = ['L','M','X','J','V','S','D'];
const DAYS_FULL = ['lunes','martes','miércoles','jueves','viernes','sábado','domingo'];
// JS: 0=Sun,1=Mon,... we use Mon=0..Sun=6
const TIME_ORDER = { morning: 1, afternoon: 2, night: 3, custom: 4, anytime: 5 };
const DOT_COLORS = ['#c8f060','#06d6a0','#ffd166','#a29bfe','#ff6b81','#4dd0e1','#f6c90e','#fc9d59'];

let habits = [];
let logs = {}; // { 'YYYY-MM-DD': { habitId: count } }
let editingId = null;
let weeklyTimes = 3;
let selectedEmoji = '💪';
let selectedFreq = 'daily';
let selectedTime = 'anytime';
let notifOn = false;
let selectedDays = [];
let statsMonth = new Date();
let statsHabitFilter = null;
let deferredPrompt = null;

function load() {
  habits = JSON.parse(localStorage.getItem('habits_v2') || '[]');
  logs = JSON.parse(localStorage.getItem('logs_v2') || '{}');
}
function save() {
  localStorage.setItem('habits_v2', JSON.stringify(habits));
  localStorage.setItem('logs_v2', JSON.stringify(logs));
}

// ════════════════════════════════════════════════
//  DATE HELPERS
// ════════════════════════════════════════════════
function today() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}
function dateKey(d) {
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}
function jsDayToMon(d) { return (d.getDay() + 6) % 7; } // Mon=0..Sun=6

function isHabitDueToday(h) {
  const d = new Date();
  const dayMon = jsDayToMon(d);
  if (h.freq === 'daily') return true;
  if (h.freq === 'days') return h.days.includes(dayMon);
  if (h.freq === 'weekly') {
    // Check if already done enough times this week
    const done = getWeeklyCount(h.id);
    return done < h.weeklyTimes;
  }
  return true;
}

function getWeekCount(date) {
  // Start of current week (Monday)
  const d = new Date(date);
  const day = d.getDay();
  const diff = d.getDate() - day + (day === 0 ? -6 : 1);
  d.setDate(diff);
  d.setHours(0,0,0,0);
  return d;
}

function getWeeklyCount(habitId) {
  const weekStart = getWeekCount(new Date());
  let count = 0;
  for (let i = 0; i < 7; i++) {
    const d = new Date(weekStart);
    d.setDate(d.getDate() + i);
    const k = dateKey(d);
    if (logs[k] && logs[k][habitId]) count += logs[k][habitId];
  }
  return count;
}

function getTodayCount(habitId) {
  const t = today();
  return (logs[t] && logs[t][habitId]) || 0;
}

function getHabitDoneCount(h) {
  if (h.freq === 'daily' || h.freq === 'days') return getTodayCount(h.id);
  if (h.freq === 'weekly') return getWeeklyCount(h.id);
  return 0;
}

function getHabitTarget(h) {
  if (h.freq === 'weekly') return h.weeklyTimes;
  return 1;
}

function isHabitComplete(h) {
  return getHabitDoneCount(h) >= getHabitTarget(h);
}

// ════════════════════════════════════════════════
//  SCREENS
// ════════════════════════════════════════════════
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  if (name === 'today') {
    document.getElementById('screenToday').classList.add('active');
    document.getElementById('navToday').classList.add('active');
    renderToday();
  } else if (name === 'habits') {
    document.getElementById('screenHabits').classList.add('active');
    document.getElementById('navHabits').classList.add('active');
    renderHabitsList();
  } else if (name === 'stats') {
    document.getElementById('screenStats').classList.add('active');
    document.getElementById('navStats').classList.add('active');
    renderStats();
  }
}

// ════════════════════════════════════════════════
//  TODAY SCREEN
// ════════════════════════════════════════════════
function sortedHabitsForToday() {
  return habits
    .filter(h => isHabitDueToday(h))
    .sort((a, b) => {
      // sort by time order, then custom time
      const ao = TIME_ORDER[a.timeSlot] || 5;
      const bo = TIME_ORDER[b.timeSlot] || 5;
      if (ao !== bo) return ao - bo;
      if (a.timeSlot === 'custom' && b.timeSlot === 'custom') {
        return (a.customTime || '').localeCompare(b.customTime || '');
      }
      return 0;
    });
}

function renderToday() {
  const list = document.getElementById('todayList');
  const all = sortedHabitsForToday();
  const pending = all.filter(h => !isHabitComplete(h));
  const done = all.filter(h => isHabitComplete(h));

  if (all.length === 0) {
    list.innerHTML = `<div class="empty-state"><div class="big-emoji">🌱</div><p>No tienes hábitos para hoy.<br>Pulsa + para crear el primero.</p></div>`;
    return;
  }

  let html = '';
  if (pending.length) {
    html += `<div class="section-label">Pendientes</div>`;
    pending.forEach(h => { html += habitCardHTML(h, false); });
  }
  if (done.length) {
    html += `<div class="section-label">Completados 🎉</div>`;
    done.forEach(h => { html += habitCardHTML(h, true); });
  }
  list.innerHTML = html;
}

function habitCardHTML(h, isDone) {
  const done = getHabitDoneCount(h);
  const target = getHabitTarget(h);
  const timeBadge = timeSlotBadge(h);
  const progress = target > 1 ? `<span class="habit-progress${done >= target ? ' full' : ''}">${done}/${target}</span>` : '';
  const doneEmoji = isDone ? '<span class="done-emoji">✨</span>' : '';

  return `<div class="habit-card${isDone ? ' done' : ''}">
    <div class="habit-emoji">${h.emoji}</div>
    <div class="habit-info">
      <div class="habit-name">${h.name}${doneEmoji}</div>
      <div class="habit-meta">${timeBadge}${progress}</div>
    </div>
    <button class="check-btn${isDone ? ' checked' : ''}" onclick="toggleHabit('${h.id}')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
    </button>
  </div>`;
}

function timeSlotBadge(h) {
  const map = {
    morning: `<span class="habit-time-badge badge-morning">🌅 Mañana</span>`,
    afternoon: `<span class="habit-time-badge badge-afternoon">☀️ Tarde</span>`,
    night: `<span class="habit-time-badge badge-night">🌙 Noche</span>`,
    custom: `<span class="habit-time-badge badge-anytime">🕐 ${h.customTime || ''}</span>`,
    anytime: ''
  };
  return map[h.timeSlot] || '';
}

function toggleHabit(id) {
  const h = habits.find(x => x.id === id);
  if (!h) return;
  const t = today();
  if (!logs[t]) logs[t] = {};

  const done = getHabitDoneCount(h);
  const target = getHabitTarget(h);

  if (done >= target) {
    // Uncheck: reduce count
    if (logs[t][id] > 0) logs[t][id]--;
    else {
      // For weekly, find most recent day
      const weekStart = getWeekCount(new Date());
      for (let i = 6; i >= 0; i--) {
        const d = new Date(weekStart);
        d.setDate(d.getDate() + i);
        const k = dateKey(d);
        if (logs[k] && logs[k][id] > 0) { logs[k][id]--; break; }
      }
    }
  } else {
    logs[t][id] = (logs[t][id] || 0) + 1;
    if (getHabitDoneCount(h) >= target) {
      showToast(`${h.emoji} ¡${h.name} completado!`);
    }
  }
  save();
  renderToday();
}

// ════════════════════════════════════════════════
//  HABITS MANAGE
// ════════════════════════════════════════════════
function renderHabitsList() {
  const el = document.getElementById('habitsList');
  const empty = document.getElementById('habitsEmpty');
  if (!habits.length) { el.innerHTML = ''; empty.style.display = 'flex'; return; }
  empty.style.display = 'none';
  el.innerHTML = habits.map(h => `
    <div class="habit-list-item">
      <div class="hi-emoji">${h.emoji}</div>
      <div class="hi-info">
        <div class="hi-name">${h.name}</div>
        <div class="hi-freq">${freqLabel(h)}</div>
      </div>
      <div class="hi-actions">
        <button class="icon-btn" onclick="openModal('edit','${h.id}')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
        <button class="icon-btn del" onclick="confirmDeleteHabit('${h.id}')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
        </button>
      </div>
    </div>
  `).join('');
}

function freqLabel(h) {
  if (h.freq === 'daily') return '📅 Diario';
  if (h.freq === 'weekly') return `📅 ${h.weeklyTimes}x/semana`;
  if (h.freq === 'days') return `📅 ${h.days.map(d => DAYS_LABELS[d]).join(', ')}`;
  return '';
}

// ════════════════════════════════════════════════
//  MODAL
// ════════════════════════════════════════════════
function openModal(mode, id) {
  editingId = null;
  // Reset
  selectedEmoji = '💪'; selectedFreq = 'daily'; selectedTime = 'anytime'; notifOn = false; selectedDays = []; weeklyTimes = 3;
  document.getElementById('habitName').value = '';
  document.getElementById('customTime').value = '08:00';
  document.getElementById('notifTime').value = '08:00';
  document.getElementById('weeklyField').style.display = 'none';
  document.getElementById('daysField').style.display = 'none';
  document.getElementById('customTimeField').style.display = 'none';
  document.getElementById('notifTimeField').style.display = 'none';
  document.getElementById('notifToggle').classList.remove('on');
  document.getElementById('modalHabitDelete').style.display = 'none';

  buildEmojiGrid();
  updateFreqUI();
  updateTimeUI();

  if (mode === 'edit' && id) {
    const h = habits.find(x => x.id === id);
    if (!h) return;
    editingId = id;
    selectedEmoji = h.emoji;
    selectedFreq = h.freq;
    selectedTime = h.timeSlot;
    weeklyTimes = h.weeklyTimes || 3;
    selectedDays = h.days ? [...h.days] : [];
    notifOn = h.notifOn || false;
    document.getElementById('habitName').value = h.name;
    document.getElementById('customTime').value = h.customTime || '08:00';
    document.getElementById('notifTime').value = h.notifTime || '08:00';
    if (notifOn) document.getElementById('notifToggle').classList.add('on');
    document.getElementById('modalHabitTitle').textContent = 'Editar hábito';
    document.getElementById('modalHabitDelete').style.display = 'block';
    buildEmojiGrid();
    updateFreqUI();
    updateTimeUI();
    updateDaysUI();
  } else {
    document.getElementById('modalHabitTitle').textContent = 'Nuevo hábito';
  }

  document.getElementById('modalHabit').classList.add('open');
}

function buildEmojiGrid() {
  document.getElementById('emojiGrid').innerHTML = EMOJIS.map(e =>
    `<div class="emoji-opt${e === selectedEmoji ? ' selected' : ''}" onclick="pickEmoji('${e}')">${e}</div>`
  ).join('');
}

function pickEmoji(e) { selectedEmoji = e; buildEmojiGrid(); }

function selectFreq(f) {
  selectedFreq = f;
  document.querySelectorAll('#freqPills .pill').forEach(p => p.classList.toggle('selected', p.dataset.freq === f));
  updateFreqUI();
}
function updateFreqUI() {
  document.getElementById('weeklyField').style.display = selectedFreq === 'weekly' ? 'block' : 'none';
  document.getElementById('daysField').style.display = selectedFreq === 'days' ? 'block' : 'none';
  document.getElementById('weeklyTimesDisplay').textContent = weeklyTimes;
  if (selectedFreq === 'days') updateDaysUI();
}

function updateDaysUI() {
  document.getElementById('daysGrid').innerHTML = DAYS_LABELS.map((d, i) =>
    `<button class="day-btn${selectedDays.includes(i) ? ' selected' : ''}" onclick="toggleDay(${i})">${d}</button>`
  ).join('');
}
function toggleDay(i) {
  const idx = selectedDays.indexOf(i);
  if (idx >= 0) selectedDays.splice(idx, 1); else selectedDays.push(i);
  updateDaysUI();
}

function changeWeeklyTimes(d) {
  weeklyTimes = Math.max(1, Math.min(7, weeklyTimes + d));
  document.getElementById('weeklyTimesDisplay').textContent = weeklyTimes;
}

function selectTime(t) {
  selectedTime = t;
  document.querySelectorAll('#timePills .pill').forEach(p => p.classList.toggle('selected', p.dataset.time === t));
  updateTimeUI();
}
function updateTimeUI() {
  document.getElementById('customTimeField').style.display = selectedTime === 'custom' ? 'block' : 'none';
}

function toggleNotif() {
  notifOn = !notifOn;
  document.getElementById('notifToggle').classList.toggle('on', notifOn);
  document.getElementById('notifTimeField').style.display = notifOn ? 'block' : 'none';
  if (notifOn) requestNotifPermission();
}

function saveHabit() {
  const name = document.getElementById('habitName').value.trim();
  if (!name) { showToast('Ponle un nombre al hábito'); return; }

  const habit = {
    id: editingId || `h_${Date.now()}`,
    name, emoji: selectedEmoji,
    freq: selectedFreq, weeklyTimes,
    days: [...selectedDays],
    timeSlot: selectedTime,
    customTime: document.getElementById('customTime').value,
    notifOn, notifTime: document.getElementById('notifTime').value,
    color: DOT_COLORS[habits.length % DOT_COLORS.length]
  };

  if (editingId) {
    const idx = habits.findIndex(h => h.id === editingId);
    habit.color = habits[idx].color;
    habits[idx] = habit;
  } else {
    habits.push(habit);
  }
  save();
  closeModal('modalHabit');
  showToast(editingId ? '✅ Hábito actualizado' : '🎉 Hábito creado');
  renderToday();
  renderHabitsList();

  if (habit.notifOn) scheduleNotification(habit);
}

function deleteHabit() {
  if (!editingId) return;
  habits = habits.filter(h => h.id !== editingId);
  save();
  closeModal('modalHabit');
  showToast('🗑️ Hábito eliminado');
  renderToday();
  renderHabitsList();
}

function confirmDeleteHabit(id) {
  const h = habits.find(x => x.id === id);
  if (!h) return;
  if (confirm(`¿Eliminar "${h.name}"?`)) {
    habits = habits.filter(x => x.id !== id);
    save();
    renderHabitsList();
    renderToday();
    showToast('🗑️ Hábito eliminado');
  }
}

// ════════════════════════════════════════════════
//  STATS
// ════════════════════════════════════════════════
function changeStatsMonth(d) {
  statsMonth = new Date(statsMonth.getFullYear(), statsMonth.getMonth() + d, 1);
  const now = new Date();
  document.getElementById('statsNextBtn').style.opacity = (statsMonth.getFullYear() === now.getFullYear() && statsMonth.getMonth() === now.getMonth()) ? '0.3' : '1';
  renderStats();
}

function renderStats() {
  const now = new Date();
  const m = statsMonth;
  const months = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  document.getElementById('statsMonthName').textContent = `${months[m.getMonth()]} ${m.getFullYear()}`;

  // Filter
  const filterEl = document.getElementById('statsFilter');
  filterEl.innerHTML = `<div class="filter-chip${statsHabitFilter === null ? ' active' : ''}" onclick="setStatsFilter(null)">Todos</div>` +
    habits.map(h => `<div class="filter-chip${statsHabitFilter === h.id ? ' active' : ''}" onclick="setStatsFilter('${h.id}')">${h.emoji} ${h.name}</div>`).join('');

  // Summary
  const visibleHabits = statsHabitFilter ? habits.filter(h => h.id === statsHabitFilter) : habits;
  const daysInMonth = new Date(m.getFullYear(), m.getMonth() + 1, 0).getDate();
  let totalDone = 0;
  for (let day = 1; day <= daysInMonth; day++) {
    const dk = dateKey(new Date(m.getFullYear(), m.getMonth(), day));
    if (!logs[dk]) continue;
    visibleHabits.forEach(h => { if (logs[dk][h.id]) totalDone += logs[dk][h.id]; });
  }
  const streak = calcStreak();
  document.getElementById('statsSummary').innerHTML = `
    <div class="stat-box"><div class="stat-val">${totalDone}</div><div class="stat-lbl">Completados este mes</div></div>
    <div class="stat-box"><div class="stat-val">${streak}</div><div class="stat-lbl">Racha actual 🔥</div></div>
  `;

  // Calendar
  renderStatsCalendar(m, visibleHabits);
}

function setStatsFilter(id) { statsHabitFilter = id; renderStats(); }

function renderStatsCalendar(m, visibleHabits) {
  const cal = document.getElementById('statsCalendar');
  const firstDay = new Date(m.getFullYear(), m.getMonth(), 1);
  const daysInMonth = new Date(m.getFullYear(), m.getMonth() + 1, 0).getDate();
  let startDow = jsDayToMon(firstDay); // 0=Mon
  const todayStr = today();

  let html = DAYS_LABELS.map(d => `<div class="cal-day-header">${d}</div>`).join('');

  // Empty cells before
  for (let i = 0; i < startDow; i++) html += `<div class="cal-day other-month"></div>`;

  for (let day = 1; day <= daysInMonth; day++) {
    const dk = dateKey(new Date(m.getFullYear(), m.getMonth(), day));
    const isToday = dk === todayStr;
    const dayLogs = logs[dk] || {};
    const dots = visibleHabits.filter(h => dayLogs[h.id] >= 1).map(h => `<div class="dot" style="background:${h.color}"></div>`).join('');
    html += `<div class="cal-day${isToday ? ' today' : ''}">
      <span>${day}</span>
      ${dots ? `<div class="cal-day-dots">${dots}</div>` : ''}
    </div>`;
  }
  cal.innerHTML = html;
}

function calcStreak() {
  let streak = 0;
  const d = new Date();
  while (true) {
    const dk = dateKey(d);
    const dayLogs = logs[dk] || {};
    const anyDone = habits.some(h => isHabitDueOnDate(h, d) && (dayLogs[h.id] || 0) >= 1);
    if (!anyDone && dk !== today()) break;
    if (anyDone) streak++;
    d.setDate(d.getDate() - 1);
    if (streak > 365) break;
  }
  return streak;
}

function isHabitDueOnDate(h, date) {
  const dow = jsDayToMon(date);
  if (h.freq === 'daily') return true;
  if (h.freq === 'days') return h.days.includes(dow);
  if (h.freq === 'weekly') return true;
  return false;
}

// ════════════════════════════════════════════════
//  NOTIFICATIONS
// ════════════════════════════════════════════════
function requestNotifPermission() {
  if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission().then(p => {
      if (p !== 'granted') {
        showToast('❌ Activa las notificaciones en ajustes');
        notifOn = false;
        document.getElementById('notifToggle').classList.remove('on');
        document.getElementById('notifTimeField').style.display = 'none';
      }
    });
  }
}

function scheduleNotification(habit) {
  if (!habit.notifOn || !('Notification' in window)) return;
  if (Notification.permission !== 'granted') return;
  // For PWA we use a basic approach: schedule via service worker if available
  // or show a toast reminder
  showToast(`🔔 Notificación configurada para ${habit.notifTime}`);
}

function openNotifSettings() {
  const el = document.getElementById('notifList');
  const withNotif = habits.filter(h => h.notifOn);
  if (!withNotif.length) {
    el.innerHTML = `<div style="color:var(--text-muted);font-size:14px;text-align:center;padding:20px 0;">Ningún hábito tiene notificaciones activadas.<br>Edita un hábito para configurarlas.</div>`;
  } else {
    el.innerHTML = withNotif.map(h => `
      <div class="habit-list-item">
        <div class="hi-emoji">${h.emoji}</div>
        <div class="hi-info">
          <div class="hi-name">${h.name}</div>
          <div class="hi-freq">🔔 ${h.notifTime}</div>
        </div>
      </div>
    `).join('');
  }
  document.getElementById('modalNotif').classList.add('open');
}

// ════════════════════════════════════════════════
//  UTILS
// ════════════════════════════════════════════════
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function closeModalOutside(e, id) { if (e.target === document.getElementById(id)) closeModal(id); }

let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
}

function initHeader() {
  const days = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
  const months = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
  const d = new Date();
  document.getElementById('headerDate').textContent = `${days[d.getDay()]}, ${d.getDate()} ${months[d.getMonth()]}`;
}

function updateStreakBadge() {
  const s = calcStreak();
  document.getElementById('streakBadge').textContent = s > 0 ? `🔥 ${s}` : '';
}

// Clean old stats (keep only current + previous month)
function cleanOldLogs() {
  const now = new Date();
  const keepMonths = [
    `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`,
    `${new Date(now.getFullYear(), now.getMonth()-1).getFullYear()}-${String(new Date(now.getFullYear(), now.getMonth()-1).getMonth()+1).padStart(2,'0')}`
  ];
  Object.keys(logs).forEach(k => {
    if (!keepMonths.some(m => k.startsWith(m))) delete logs[k];
  });
  save();
}

// Install banner for iOS
function checkInstallBanner() {
  const isIOS = /iphone|ipad|ipod/.test(navigator.userAgent.toLowerCase());
  const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;
  const dismissed = localStorage.getItem('installDismissed');
  if (isIOS && !isStandalone && !dismissed) {
    document.getElementById('installBanner').classList.add('show');
  }
}

// ════════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════════
load();
cleanOldLogs();
initHeader();
updateStreakBadge();
checkInstallBanner();

// Stats init
const nowMonth = new Date();
statsMonth = new Date(nowMonth.getFullYear(), nowMonth.getMonth(), 1);

showScreen('today');

// Daily notification check via setInterval
setInterval(() => {
  if (Notification.permission !== 'granted') return;
  const now = new Date();
  const hhmm = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
  habits.forEach(h => {
    if (!h.notifOn) return;
    if (h.notifTime !== hhmm) return;
    if (!isHabitDueToday(h)) return;
    if (isHabitComplete(h)) return;
    new Notification(`${h.emoji} ${h.name}`, { body: 'Es hora de tu hábito diario', icon: '' });
  });
}, 60000);
</script>

